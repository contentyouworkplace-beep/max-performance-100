# ── Email (Resend — free tier: 3,000/month, 100/day) ────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sender — domain must be verified in Resend (Domains → Add Domain)
EMAIL_FROM="MaxPerformance100 <support@maxperformance100.com>"
# Where sale/lead notifications go (also used as reply-to)
OWNER_NOTIFY_EMAIL=support.maxperformance100@gmail.com

# ── Downloads ────────────────────────────────────────────────────────
# Long random string used to sign download links. Generate with:
#   openssl rand -hex 32
DOWNLOAD_SECRET=change-me-to-a-long-random-string

# ── PayPal ───────────────────────────────────────────────────────────
# Must match the "business" email in the Buy Now buttons
PAYPAL_BUSINESS_EMAIL=dchtristate@gmail.com
# "live" for real payments, "sandbox" for testing
PAYPAL_ENV=live

# ── Site ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://maxperformance100.com

# ── Microsoft Clarity (free) ─────────────────────────────────────────
# Project ID from https://clarity.microsoft.com → Settings → Overview
NEXT_PUBLIC_CLARITY_PROJECT_ID=
